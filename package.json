{
  "name": "acep-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3100",
    "dev:docker": "next dev -p 3100 -H 0.0.0.0",
    "build": "prisma generate && next build",
    "start": "next start -p 3100",
    "lint": "next lint",
    "scrape:acep": "node scripts/scrape-acep.mjs --out content/acep --concurrency 6",
    "scrape:acep:assets": "node scripts/scrape-acep-assets.mjs --contentDir content/acep --concurrency 6",
    "scrape:contracts": "node scripts/scrape-contract-monitor.mjs --out content/contract-monitor --concurrency 3",
    "scrape:electricity": "node scripts/scrape-electricity-monitor.mjs --out content/electricity-monitor --concurrency 3",
    "scrape:electricity:assets": "node scripts/scrape-electricity-assets.mjs --contentDir content/electricity-monitor --concurrency 6",
    "verify:electricity": "node scripts/verify-electricity-monitor.mjs",
    "scrape:oil-revenue": "node scripts/scrape-oil-revenue.mjs --out content/oil-revenue --concurrency 3",
    "scrape:oil-revenue:assets": "node scripts/scrape-oil-revenue-assets.mjs --contentDir content/oil-revenue --concurrency 6",
    "verify:oil-revenue": "node scripts/verify-oil-revenue.mjs",
    "gen:acep:routes": "node scripts/generate-acep-route-map.mjs",
    "verify:acep": "node scripts/verify-acep-coverage.mjs --port 3100 --out content/acep/local-verify.json",
    "verify:contracts": "node scripts/verify-contract-monitor.mjs",
    "docker:build": "docker build -t acep-platform .",
    "docker:run": "docker run -p 3100:3100 acep-platform",
    "docker:dev": "docker compose up --build",
    "docker:dev:db": "docker compose --profile with-db up --build",
    "docker:prod": "docker compose --profile prod up --build",
    "docker:coolify": "docker compose -f docker-compose.coolify.yml up --build",
    "verify:coolify-compose": "bash scripts/verify-coolify-compose.sh",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-navigation-menu": "^1.2.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.5",
    "@tanstack/react-query": "^5.62.12",
    "axios": "^1.7.9",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.469.0",
    "next": "^16.1.4",
    "prisma": "5.22.0",
    "react": "^18.3.1",
    "react-day-picker": "^9.13.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.12",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.1.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
