# Copy to Coolify "Environment Variables" or to `.env` next to docker-compose.coolify.yml
# Never commit real secrets.

# --- Required ---
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# --- Admin (manual migrate/seed at /admin/settings) ---
# Long random string; same value you enter in the admin UI.
ADMIN_SECRET=change-me-to-another-long-random-string

# --- Public URLs (used at Next.js build time for NEXT_PUBLIC_* and for CORS) ---
# Main site (Coolify domain for the `web` service), e.g. https://acep.example.com
NEXT_PUBLIC_SITE_URL=https://acep.example.com
# Browser-reachable API URL (Coolify domain for `backend`, or same host + path if you proxy), e.g. https://api.acep.example.com
NEXT_PUBLIC_API_URL=https://api.acep.example.com

# --- Optional overrides ---
# POSTGRES_USER=acep
# POSTGRES_DB=acep
# WEB_PUBLISH_PORT=3100
# API_PUBLISH_PORT=3001

# --- Optional Redis password ---
# Set REDIS_PASSWORD to enable Redis AUTH. Backend resolves REDIS_URL automatically unless you set REDIS_URL.
# For the Next.js `web` service, when using a password set REDIS_URL explicitly, e.g.:
# REDIS_URL=redis://:your-redis-secret@redis:6379
# (URL-encode special characters in the password.)
