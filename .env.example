# Application
NEXT_PUBLIC_SITE_URL=http://localhost:3100
NODE_ENV=development
PORT=3100
#
# Local site only runs when you start the dev server:
#   npm run dev
#   — or (Postgres + dev):  npm run dev:stack

# Coolify / VPS full stack (Postgres + Redis + API + Next): see docker-compose.coolify.yml and COOLIFY.md
# Copy .env.coolify.example → set POSTGRES_PASSWORD, NEXT_PUBLIC_SITE_URL, NEXT_PUBLIC_API_URL

# Prisma (local): after clone or schema change, run `npx prisma generate` (needs DATABASE_URL only for migrate/studio).

# Database (Phase 2 - PostgreSQL on Render)
# DATABASE_URL=postgresql://user:password@host:5432/database
#
# Local PostgreSQL via Docker Compose (`--profile with-db`):
# Host 54320 maps to the container; avoids conflict with a local Postgres on 5432.
# DATABASE_URL=postgresql://acep:acep_dev@localhost:54320/acep
#
# If DATABASE_URL points at a host that is not running, the app adds connect_timeout=10s
# so pages (e.g. `/`) do not hang forever waiting for Postgres.
#
# Redis (Coolify stack / Phase 2):
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=optional-for-auth

# CMS admin bootstrap (used by `npx prisma db seed` and Coolify deploy seed)
# Production: use the same values as on the VPS, e.g. admin@acep.africa
# CMS_ADMIN_EMAIL=admin@acep.africa
# CMS_ADMIN_PASSWORD=set-a-strong-password
# CMS_ADMIN_NAME=ACEP Africa Administrator

# Authentication (Phase 3 - NextAuth.js)
# NEXTAUTH_SECRET=your-secret-key-here
# NEXTAUTH_URL=http://localhost:3000

# Media Storage (Phase 3 - Cloudinary)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Participant portal — email staff when organiser materials are submitted for review (requires RESEND_API_KEY)
# PORTAL_SUBMISSION_NOTIFY_EMAIL=events@acep.africa

# Public forms (electricity / OpenTax) — optional staff alert when a row is stored (requires RESEND_API_KEY)
# PUBLIC_FORM_NOTIFY_EMAIL=compliance@acep.africa

# Events — optional real emails via Resend; without these, server logs the confirm link
# RESEND_API_KEY=
# EVENT_EMAIL_FROM="ACEP Events <events@yourdomain.com>"
# Optional 6-digit hex for HTML email CTA button (default #0c4a6e)
# EVENT_EMAIL_BRAND_COLOR=#0c4a6e
# Public registration API: max POSTs per IP+event per window
# EVENT_PUBLIC_API_RATE_MAX=30
# EVENT_PUBLIC_API_RATE_WINDOW_SEC=60
# Optional Upstash (shared across instances). If unset, uses in-memory limiter per instance.
# Create a Redis database at upstash.com — REST URL + token
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Analytics (Optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
